---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  ogTitle?: string
}

const { title, description, ogTitle } = Astro.props

// Ensure trailing slashes are removed from the canonical URL to match Google Ads expectations
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/'
const canonicalURL = new URL(pathname, Astro.site || 'https://usvisarequirements.com')
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SFBE8BSBHG"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-SFBE8BSBHG');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/android-chrome-192x192.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="shortcut icon" href="/favicon.ico" />
    
    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-6703697182972972">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6703697182972972" crossorigin="anonymous"></script>
  </head>
  <body>
    <slot />

    <footer class="site-footer">
      <div class="footer-inner">
        <p>Data sourced from <a href="https://travel.state.gov" rel="nofollow noreferrer">travel.state.gov</a></p>
        <p>Updated monthly &middot; &copy; {new Date().getFullYear()}</p>
      </div>
    </footer>
  </body>
</html>
